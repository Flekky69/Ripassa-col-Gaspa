// ─── STATE ─────────────────────────────────────────────────────────────────
let mode = "quiz";
let filter = "all";
let deck = [];
let idx = 0;
let flipped = false;

function filteredCards() {
  return filter === "all" ? [...cards] : cards.filter(c => c.cat === filter);
}

function shuffle() {
  for (let i = deck.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [deck[i], deck[j]] = [deck[j], deck[i]];
  }
  idx = 0;
  flipped = false;
  document.getElementById("score-panel").classList.remove("visible");
  renderQuiz();
}

function restart() {
  deck = filteredCards();
  shuffle();
}

// ─── QUIZ ───────────────────────────────────────────────────────────────────
function renderQuiz() {
  const total = deck.length;
  const card = deck[idx];
  document.getElementById("qcounter").textContent = `${idx + 1} / ${total}`;
  document.getElementById("qpf").style.width = `${((idx) / total) * 100}%`;

  const fc = document.getElementById("flip-card");
  fc.dataset.cat = card.cat;
  fc.classList.remove("flipped");
  flipped = false;

  document.getElementById("fc-tag").textContent =
    card.cat === "teoria" ? "Teoria" : card.cat === "esercizio" ? "Esercizio" : "Ragionamento";
  document.getElementById("fc-q").innerHTML = card.q;
  document.getElementById("fc-a").innerHTML = card.a;

  document.getElementById("btn-prev").disabled = idx === 0;
  document.getElementById("btn-next").textContent = idx === total - 1 ? "Fine ✓" : "Avanti →";

  document.getElementById("score-panel").classList.remove("visible");
  document.getElementById("flip-scene").style.display = "block";

  // Re-run MathJax
  if (window.MathJax) MathJax.typesetPromise([document.getElementById("flip-card")]);
}

function flipCard() {
  flipped = !flipped;
  document.getElementById("flip-card").classList.toggle("flipped", flipped);
  if (flipped && window.MathJax)
    MathJax.typesetPromise([document.getElementById("fc-a")]);
}

function nextCard() {
  if (idx < deck.length - 1) {
    idx++;
    renderQuiz();
  } else {
    // End
    document.getElementById("flip-scene").style.display = "none";
    document.getElementById("quiz-counter-area")?.hide?.();
    document.getElementById("score-num").textContent = deck.length;
    document.getElementById("score-panel").classList.add("visible");
    document.getElementById("qpf").style.width = "100%";
  }
}

function prevCard() {
  if (idx > 0) { idx--; renderQuiz(); }
}

// ─── BROWSE ─────────────────────────────────────────────────────────────────
function renderBrowse() {
  const view = document.getElementById("browse-view");
  view.innerHTML = "";
  const shown = filteredCards();
  shown.forEach((card, i) => {
    const div = document.createElement("div");
    div.className = "browse-card";
    div.dataset.cat = card.cat;
    const tagClass = `tag-${card.cat}`;
    const tagLabel = card.cat === "teoria" ? "Teoria" : card.cat === "esercizio" ? "Esercizio" : "Ragionamento";
    const globalIdx = cards.indexOf(card) + 1;
    div.innerHTML = `
      <div class="bc-header">
        <span class="bc-num">#${globalIdx}</span>
        <span class="bc-tag ${tagClass}">${tagLabel}</span>
      </div>
      <div class="bc-q">${card.q}</div>
      <div class="bc-divider"></div>
      <div class="bc-a-label">Risposta</div>
      <div class="bc-a">${card.a}</div>
    `;
    view.appendChild(div);
  });
  if (window.MathJax) MathJax.typesetPromise([view]);
}

// ─── SWITCHES ───────────────────────────────────────────────────────────────
function setMode(m) {
  mode = m;
  document.querySelectorAll(".mode-btn").forEach(b => b.classList.toggle("active", b.dataset.mode === m));
  document.getElementById("quiz-view").style.display = m === "quiz" ? "flex" : "none";
  document.getElementById("browse-view").style.display = m === "browse" ? "grid" : "none";
  if (m === "browse") renderBrowse();
  if (m === "quiz") { deck = filteredCards(); idx = 0; flipped = false; renderQuiz(); }
}

function setFilter(f) {
  filter = f;
  document.querySelectorAll(".tab-btn").forEach(b => b.classList.toggle("active", b.dataset.filter === f));
  const count = filteredCards().length;
  document.getElementById("stat-pill").textContent = `${count} carte`;
  if (mode === "quiz") {
    deck = filteredCards();
    idx = 0; flipped = false;
    document.getElementById("score-panel").classList.remove("visible");
    document.getElementById("flip-scene").style.display = "block";
    renderQuiz();
  } else {
    renderBrowse();
  }
}

// ─── EVENTS ─────────────────────────────────────────────────────────────────
document.querySelectorAll(".tab-btn").forEach(b => b.addEventListener("click", () => setFilter(b.dataset.filter)));
document.querySelectorAll(".mode-btn").forEach(b => b.addEventListener("click", () => setMode(b.dataset.mode)));

// Keyboard navigation
document.addEventListener("keydown", e => {
  if (mode !== "quiz") return;
  if (e.key === "ArrowRight" || e.key === "ArrowDown") nextCard();
  if (e.key === "ArrowLeft" || e.key === "ArrowUp") prevCard();
  if (e.key === " " || e.key === "Enter") { e.preventDefault(); flipCard(); }
});

// ─── INIT ───────────────────────────────────────────────────────────────────
window.addEventListener("load", () => {
  deck = filteredCards();
  renderQuiz();
});
</script>
</body>
</html>
